    "WhisperKit lädt das Modell beim ersten Mal einmalig herunter; danach läuft alles offline.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WhisperKit downloads the model once on first use; after that everything runs offline."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "WhisperKit télécharge le modèle une seule fois lors de la première utilisation ; ensuite tout fonctionne hors ligne."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "WhisperKit descarga el modelo una sola vez en el primer uso; después todo funciona sin conexión."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
