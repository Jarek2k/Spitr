    "Taste halten, sprechen, loslassen — der Text landet im aktiven Fenster. Alles on-device, ohne Cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold a key, speak, release — the text lands in the active window. All on-device, no cloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintiens une touche, parle, relâche — le texte arrive dans la fenêtre active. Tout sur l'appareil, sans cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén una tecla, habla, suelta — el texto aparece en la ventana activa. Todo en el dispositivo, sin nube."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto un tasto, parla, rilascia — il testo arriva nella finestra attiva. Tutto on-device, senza cloud."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj klawisz, mów, puść — tekst trafia do aktywnego okna. Wszystko na urządzeniu, bez chmury."
          }
        }
      }
    },
    "Mikrofon": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Microphone"
          }
        },
        "fr": {
          "stringUnit": {
