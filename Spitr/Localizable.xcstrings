          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikrofon"
          }
        }
      }
    },
    "Nimmt nur auf, solange du die Aufnahme-Taste hältst. Kein Dauer-Mithören.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Records only while you hold the recording key. No always-on listening."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "N'enregistre que tant que tu maintiens la touche d'enregistrement. Aucune écoute permanente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo graba mientras mantienes la tecla de grabación. Sin escucha continua."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra solo mentre tieni premuto il tasto di registrazione. Nessun ascolto continuo."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nagrywa tylko, gdy trzymasz klawisz nagrywania. Bez ciągłego nasłuchiwania."
          }
        }
      }
    },
    "Spracherkennung": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Speech recognition"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconnaissance vocale"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Reconocimiento de voz"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Riconoscimento vocale"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozpoznawanie mowy"
          }
        }
      }
    },
    "Wandelt deine Aufnahme on-device in Text um.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Converts your recording to text on-device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Convertit ton enregistrement en texte sur l'appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Convierte tu grabación en texto en el dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Converte la tua registrazione in testo on-device."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zamienia nagranie na tekst na urządzeniu."
          }
        }
      }
    },
    "Bedienungshilfen": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibilité"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesibilidad"
