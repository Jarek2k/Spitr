    "Nimmt nur auf, solange du die Aufnahme-Taste hältst. Kein Dauer-Mithören." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Records only while you hold the recording key. No always-on listening."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo graba mientras mantienes la tecla de grabación. Sin escucha continua."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "N'enregistre que tant que tu maintiens la touche d'enregistrement. Aucune écoute permanente."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra solo mentre tieni premuto il tasto di registrazione. Nessun ascolto continuo."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nagrywa tylko, gdy trzymasz klawisz nagrywania. Bez ciągłego nasłuchiwania."
          }
        }
      }
    },
    "Noch keine Regeln. „Erkannt“ wird durch „Ersetzung“ getauscht." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No rules yet. “Recognized” is swapped for “Replacement”."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no hay reglas. «Reconocido» se cambia por «Reemplazo»."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucune règle pour l'instant. « Reconnu » est remplacé par « Remplacement »."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ancora nessuna regola. «Riconosciuto» viene sostituito con «Sostituzione»."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brak reguł. „Rozpoznane” jest zamieniane na „Zamiennik”."
          }
        }
      }
    },
