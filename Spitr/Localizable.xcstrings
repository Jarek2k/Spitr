    "Letzte Spracheingabe korrigieren…": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Correct last dictation…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Corriger la dernière dictée…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Corregir el último dictado…"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Correggi l'ultima dettatura…"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Popraw ostatnie dyktowanie…"
          }
        }
      }
    },
    "Letzte Spracheingabe ausbessern und die Korrektur optional als feste Wörterbuch-Regel sichern.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fix the last dictation and optionally save the correction as a permanent dictionary rule."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrige la dernière dictée et enregistre éventuellement la correction comme règle de dictionnaire permanente."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Corrige el último dictado y, si quieres, guarda la corrección como una regla de diccionario permanente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Correggi l'ultima dettatura e, se vuoi, salva la correzione come regola permanente del dizionario."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Popraw ostatnie dyktowanie i opcjonalnie zapisz poprawkę jako stałą regułę słownika."
          }
        }
      }
    },
    "Spracheingabe korrigieren": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Correct dictation"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Corriger la dictée"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Corregir dictado"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Correggi dettatura"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Popraw dyktowanie"
          }
        }
      }
    },
    "Tippe das falsch erkannte Wort an und gib ein, wodurch es ersetzt werden soll. Die Regel gilt dann automatisch für alle künftigen Spracheingaben.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the misrecognized word and enter what it should be replaced with. The rule then applies automatically to all future voice input."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touche le mot mal reconnu et indique par quoi le remplacer. La règle s'applique alors automatiquement à toutes les dictées futures."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca la palabra mal reconocida e indica por qué reemplazarla. La regla se aplicará automáticamente a todos los dictados futuros."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca la parola riconosciuta male e indica con cosa sostituirla. La regola verrà poi applicata automaticamente a tutte le dettature future."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotknij błędnie rozpoznanego słowa i podaj, czym je zastąpić. Reguła będzie wtedy automatycznie obowiązywać dla wszystkich przyszłych dyktowań."
          }
        }
      }
    },
    "Tastenkombination drücken…": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press shortcut…"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur le raccourci…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa el atajo…"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi la scorciatoia…"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij skrót…"
          }
        }
      }
    },
    "Drücke die gewünschte Kombination, Esc bricht ab.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press the desired combination, Esc cancels."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur la combinaison souhaitée, Échap annule."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa la combinación deseada, Esc cancela."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi la combinazione desiderata, Esc annulla."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij żądaną kombinację, Esc anuluje."
          }
        }
      }
    },
    "Klicken, dann Kombination drücken.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click, then press the combination."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clique, puis appuie sur la combinaison."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haz clic y luego pulsa la combinación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai clic, poi premi la combinazione."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknij, a następnie naciśnij kombinację."
          }
        }
      }
    },
    "Taste halten, sprechen, loslassen — der Text landet im aktiven Fenster.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold a key, speak, release — the text lands in the active window."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintiens une touche, parle, relâche — le texte arrive dans la fenêtre active."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén una tecla, habla, suelta — el texto aparece en la ventana activa."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto un tasto, parla, rilascia — il testo arriva nella finestra attiva."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj klawisz, mów, puść — tekst trafia do aktywnego okna."
          }
        }
      }
    },
    "Diktieren": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Dictating"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dicter"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dictar"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dettare"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dyktowanie"
          }
        }
      }
    },
    "Halte die Aufnahme-Taste, sprich, lass los — der erkannte Text landet im gerade fokussierten Feld. Aufgenommen wird nur, solange du die Taste hältst.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the recording key, speak, release — the recognized text lands in the currently focused field. Recording happens only while you hold the key."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintiens la touche d'enregistrement, parle, relâche — le texte reconnu arrive dans le champ actif. L'enregistrement n'a lieu que tant que tu maintiens la touche."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén la tecla de grabación, habla, suelta — el texto reconocido aparece en el campo enfocado. La grabación solo ocurre mientras mantienes la tecla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto il tasto di registrazione, parla, rilascia — il testo riconosciuto arriva nel campo attivo. La registrazione avviene solo mentre tieni premuto il tasto."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj klawisz nagrywania, mów, puść — rozpoznany tekst trafia do aktywnego pola. Nagrywanie odbywa się tylko, gdy trzymasz klawisz."
          }
        }
      }
    },
    "Befehlsmodus": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Command mode"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mode commande"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Modo de comandos"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Modalità comandi"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryb poleceń"
          }
        }
      }
    },
    "Halte die Aufnahme-Taste zusätzlich mit ⇧ und sprich einen Befehl (z. B. »pause«, »weiter«, »WhisperKit«). Der Text wird dann ausgeführt statt eingefügt. Alle Befehle stehen in den Einstellungen unter „Befehle“.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold the recording key together with ⇧ and speak a command (e.g. »pause«, »resume«, »WhisperKit«). The text is executed instead of inserted. All commands are listed in Settings under “Commands”."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintiens la touche d'enregistrement avec ⇧ et prononce une commande (p. ex. »pause«, »reprendre«, »WhisperKit«). Le texte est exécuté au lieu d'être inséré. Toutes les commandes sont dans les Réglages sous « Commandes »."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén la tecla de grabación junto con ⇧ y di un comando (p. ej. »pausa«, »continuar«, »WhisperKit«). El texto se ejecuta en lugar de insertarse. Todos los comandos están en Ajustes en «Comandos»."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto il tasto di registrazione insieme a ⇧ e pronuncia un comando (es. »pausa«, »riprendi«, »WhisperKit«). Il testo viene eseguito invece di essere inserito. Tutti i comandi sono in Impostazioni alla voce «Comandi»."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj klawisz nagrywania razem z ⇧ i wypowiedz polecenie (np. »pauza«, »dalej«, »WhisperKit«). Tekst zostanie wykonany zamiast wstawiony. Wszystkie polecenia znajdziesz w Ustawieniach w sekcji „Polecenia”."
          }
        }
      }
    },
    "Aufnahme abbrechen": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel recording"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Annuler l'enregistrement"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancelar grabación"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Annulla registrazione"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Anuluj nagrywanie"
          }
        }
      }
    },
    "Drücke Esc, während du die Aufnahme-Taste hältst. Nichts wird transkribiert oder eingefügt — praktisch bei einem Versprecher.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press Esc while holding the recording key. Nothing is transcribed or inserted — handy after a slip of the tongue."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur Échap tout en maintenant la touche d'enregistrement. Rien n'est transcrit ni inséré — pratique après un lapsus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa Esc mientras mantienes la tecla de grabación. No se transcribe ni se inserta nada — útil tras un desliz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi Esc mentre tieni premuto il tasto di registrazione. Niente viene trascritto o inserito — utile dopo un errore di pronuncia."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij Esc, trzymając klawisz nagrywania. Nic nie zostanie zapisane ani wstawione — przydatne po przejęzyczeniu."
          }
        }
      }
    },
    "War der Fokus beim Loslassen falsch, fügt der globale Kurzbefehl (Standard ⌃⌥⌘V, frei belegbar) die letzte Spracheingabe erneut ins aktive Feld ein.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the focus was wrong on release, the global shortcut (default ⌃⌥⌘V, customizable) inserts the last dictation into the active field again."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si le focus était erroné au relâchement, le raccourci global (par défaut ⌃⌥⌘V, personnalisable) réinsère la dernière dictée dans le champ actif."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si el foco era incorrecto al soltar, el atajo global (por defecto ⌃⌥⌘V, personalizable) inserta de nuevo el último dictado en el campo activo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se il focus era sbagliato al rilascio, la scorciatoia globale (predefinita ⌃⌥⌘V, personalizzabile) reinserisce l'ultima dettatura nel campo attivo."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli fokus był błędny przy puszczeniu, globalny skrót (domyślnie ⌃⌥⌘V, konfigurowalny) ponownie wstawia ostatnie dyktowanie do aktywnego pola."
          }
        }
      }
    },
    "Vokabular & Wörterbuch": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocabulary & Dictionary"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocabulaire et dictionnaire"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocabulario y diccionario"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vocabolario e dizionario"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Słownictwo i słownik"
          }
        }
      }
    },
    "„Vokabular“ gibt der Erkennung Eigennamen/Fachbegriffe als Hinweis mit (hilft oft, nicht garantiert). „Wörterbuch“ ersetzt ein Wort fest nach der Erkennung — der harte Weg, wenn ein Begriff nie korrekt ankommt.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“Vocabulary” gives recognition proper names/technical terms as a hint (often helps, not guaranteed). “Dictionary” replaces a word permanently after recognition — the hard way when a term never comes through correctly."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Vocabulaire » donne à la reconnaissance des noms propres/termes techniques comme indice (aide souvent, sans garantie). « Dictionnaire » remplace définitivement un mot après la reconnaissance — la méthode forte quand un terme ne passe jamais correctement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«Vocabulario» da al reconocimiento nombres propios/términos técnicos como pista (suele ayudar, sin garantía). «Diccionario» reemplaza una palabra de forma permanente tras el reconocimiento — la vía dura cuando un término nunca llega correctamente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Vocabolario» fornisce al riconoscimento nomi propri/termini tecnici come suggerimento (spesso aiuta, non garantito). «Dizionario» sostituisce una parola in modo permanente dopo il riconoscimento — la via dura quando un termine non arriva mai correttamente."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„Słownictwo” podpowiada rozpoznawaniu nazwy własne/terminy techniczne (często pomaga, bez gwarancji). „Słownik” trwale zastępuje słowo po rozpoznaniu — twardy sposób, gdy termin nigdy nie pojawia się poprawnie."
          }
        }
      }
    },
    "Engines": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Engines"
          }
        },
        "fr": {
          "stringUnit": {
