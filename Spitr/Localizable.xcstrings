    "Die fn-Taste wird nur von der MacBook-Tastatur erkannt, nicht von externen Tastaturen.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The fn key is only detected on the MacBook keyboard, not on external keyboards."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La touche fn n'est détectée que sur le clavier du MacBook, pas sur les claviers externes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tecla fn solo se detecta en el teclado del MacBook, no en teclados externos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tasto fn viene rilevato solo sulla tastiera del MacBook, non su tastiere esterne."
          }
        },
        "pl": {
