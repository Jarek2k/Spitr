          }
        }
      }
    },
    "Alles läuft on-device. Keine Cloud, keine Telemetrie. Einzige Ausnahme: der einmalige WhisperKit-Modell-Download.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything runs on-device. No cloud, no telemetry. The only exception: the one-time WhisperKit model download."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout fonctionne sur l'appareil. Aucun cloud, aucune télémétrie. Seule exception : le téléchargement unique du modèle WhisperKit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo funciona en el dispositivo. Sin nube, sin telemetría. La única excepción: la descarga única del modelo de WhisperKit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutto funziona on-device. Nessun cloud, nessuna telemetria. Unica eccezione: il download una tantum del modello WhisperKit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wszystko działa na urządzeniu. Bez chmury, bez telemetrii. Jedyny wyjątek: jednorazowe pobranie modelu WhisperKit."
          }
        }
      }
    },
