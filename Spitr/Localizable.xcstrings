            "value": "Aiuto Spitr"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomoc Spitr"
          }
        }
      }
    },
    "Beta — On-device Voice-to-Text für macOS.\nTaste halten, sprechen, einfügen — privat, kostenlos, ohne Cloud.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta — on-device voice-to-text for macOS.\nHold a key, speak, paste — private, free, no cloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bêta — reconnaissance vocale sur l'appareil pour macOS.\nMaintiens une touche, parle, colle — privé, gratuit, sans cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta — voz a texto en el dispositivo para macOS.\nMantén una tecla, habla, pega — privado, gratis, sin nube."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta — da voce a testo on-device per macOS.\nTieni premuto un tasto, parla, incolla — privato, gratuito, senza cloud."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Beta — zamiana mowy na tekst na urządzeniu dla macOS.\nPrzytrzymaj klawisz, mów, wklej — prywatnie, za darmo, bez chmury."
          }
        }
      }
    },
    "Willkommen bei Spitr": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to Spitr"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue dans Spitr"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te damos la bienvenida a Spitr"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Benvenuto in Spitr"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Witaj w Spitr"
          }
        }
      }
    },
    "Halte %@ und sprich.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold %@ and speak."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintiens %@ et parle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén %@ y habla."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto %@ e parla."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj %@ i mów."
          }
        }
      }
    },
    "Mit ⇧ dazu: Befehlsmodus (z. B. »pause«, »weiter«).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add ⇧: command mode (e.g. »pause«, »resume«)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avec ⇧ : mode commande (p. ex. »pause«, »reprendre«)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Con ⇧: modo de comandos (p. ej. »pausa«, »continuar«)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Con ⇧: modalità comandi (es. »pausa«, »riprendi«)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Z ⇧: tryb poleceń (np. »pauza«, »dalej«)."
          }
        }
      }
    },
