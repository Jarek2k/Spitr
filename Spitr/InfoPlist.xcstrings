{
  "sourceLanguage": "de",
  "strings": {
    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr nimmt nur auf, solange du die Aufnahmetaste hältst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr records only while you hold the recording key."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr n'enregistre que tant que tu maintiens la touche d'enregistrement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr solo graba mientras mantienes la tecla de grabación."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr registra solo mentre tieni premuto il tasto di registrazione."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr nagrywa tylko, gdy trzymasz klawisz nagrywania."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr wandelt deine Aufnahme on-device in Text um."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr converts your recording to text on-device."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr convertit ton enregistrement en texte sur l'appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr convierte tu grabación en texto en el dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr converte la tua registrazione in testo on-device."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr zamienia nagranie na tekst na urządzeniu."
          }
        }
      }
    },
    "NSAppleEventsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr fügt deinen Text per Tastendruck ein (Fallback für Nicht-QWERTZ-Layouts)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr inserts your text via a keystroke (fallback for non-QWERTY layouts)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr insère ton texte via une frappe (solution de repli pour les claviers non QWERTY)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr inserta tu texto mediante una pulsación (alternativa para teclados no QWERTY)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr inserisce il testo tramite un tasto (fallback per layout non QWERTY)."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spitr wstawia tekst za pomocą skrótu klawiszowego (zapasowo dla układów innych niż QWERTY)."
          }
        }
      }
    },
